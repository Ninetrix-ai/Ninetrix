{% endif %}


def _exec_builtin_tool(fn_name: str, fn_args: dict) -> str:
    """Dispatch a builtin tool call. Returns result string."""
{% if has_builtin_shell %}
    if fn_name == "shell":
        return _builtin_shell_exec(
            fn_args.get("command", ""),
            timeout=int(fn_args.get("timeout", 60)),
            working_dir=str(fn_args.get("working_dir", "/app")),
        )
{% endif %}
{% if has_builtin_filesystem %}
    if fn_name == "read_file":
        return _builtin_read_file(
            fn_args.get("path", ""),
            offset=int(fn_args.get("offset", 0)),
            limit=int(fn_args.get("limit", 5000)),
        )
    if fn_name == "write_file":
        return _builtin_write_file(fn_args.get("path", ""), fn_args.get("content", ""))
    if fn_name == "list_dir":
        return _builtin_list_dir(
            fn_args.get("path", "."),
            recursive=bool(fn_args.get("recursive", False)),
        )
{% endif %}
    return f"Error: unknown builtin tool '{fn_name}'"

{% endif %}
