# syntax=docker/dockerfile:1
# Generated by ninetrix — do not edit manually.
# Agent: {{ agent.name }}  |  Model: {{ agent.model }}  |  Provider: {{ agent.provider }}

FROM {{ base_image }}

LABEL org.opencontainers.image.title="{{ agent.name }}"
LABEL org.opencontainers.image.description="{{ agent.description }}"
LABEL org.opencontainers.image.source="https://github.com/ninetrix/ninetrix"

WORKDIR /app
{% if has_apt_packages %}

# System packages (apt) — cache mounts survive across builds
RUN --mount=type=cache,target=/var/cache/apt \
    --mount=type=cache,target=/var/lib/apt/lists \
    apt-get update && apt-get install -y --no-install-recommends {{ apt_packages | join(' ') }}
{% endif %}
{% if has_npm_packages %}

# npm packages — cache mount reuses downloaded packages
RUN --mount=type=cache,target=/root/.npm \
    npm install -g {{ npm_packages | join(' ') }}
{% endif %}
{% if has_pip_packages %}

# pip packages — cache mount reuses downloaded packages
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install {{ pip_packages | join(' ') }}
{% endif %}

{% set _pkgs = ["litellm>=1.50,<2.0"] -%}
{% if use_mcp_gateway -%}{% set _pkgs = _pkgs + ["httpx>=0.27"] -%}{% endif -%}
{% if agent.tools -%}{% set _pkgs = _pkgs + ["requests>=2.31"] -%}{% endif -%}
{% set _pkgs = _pkgs + ["pyyaml>=6.0", "rich>=13"] -%}
# Install Python runtime dependencies
# litellm pin: review quarterly — litellm has a history of breaking changes
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install{% for _pkg in _pkgs %} \
    "{{ _pkg }}"{% endfor %}
{% if has_composio_tools %}

# Install Composio SDK
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install composio
{% endif %}
{% if has_s3_volumes %}

# Install AWS CLI for S3 volume sync
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install awscli
{% endif %}
{% if has_webhook_triggers or is_multi_agent or is_saas_runner or has_invoke_server %}

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install "fastapi>=0.104" "uvicorn[standard]>=0.24"
{% endif %}
{% if has_schedule_triggers %}

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install "apscheduler>=3.10"
{% endif %}
{% if has_collaborators %}

RUN --mount=type=cache,target=/root/.cache/pip \
    pip install "aiohttp>=3.9"
{% endif %}
# Copy the agentfile
COPY agentfile.yaml /app/agentfile.yaml

# Copy agent entrypoint
COPY entrypoint.py /app/entrypoint.py

# Bundle ninetrix SDK — importable via /app on sys.path (no PyPI required)
# COPY ninetrix/ /app/ninetrix/
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install ninetrix-sdk
{% if has_local_tools %}

# Copy local @Tool Python files
COPY tools/ /app/tools/
{% endif %}

ENV PYTHONUNBUFFERED=1
ENV AGENTFILE_MODEL="{{ agent.model }}"
ENV AGENTFILE_PROVIDER="{{ agent.provider }}"
ENV AGENTFILE_TEMPERATURE="{{ agent.temperature }}"

{% if has_webhook_triggers %}
EXPOSE {{ webhook_port }}
{% endif %}
{% if is_multi_agent %}
EXPOSE {{ invoke_port }}
{% endif %}
# Secrets injected at runtime via env vars — never baked in
# e.g.: docker run -e ANTHROPIC_API_KEY=sk-... {{ agent.image_name() }}

ENTRYPOINT ["python", "entrypoint.py"]
