# PostgreSQL
POSTGRES_DB=ninetrix
POSTGRES_USER=ninetrix
POSTGRES_PASSWORD=changeme

# MCP Gateway
MCP_GATEWAY_SECRET=changeme-use-a-long-random-string
MCP_GATEWAY_REQUIRE_AUTH=true
MCP_WORKSPACE_ID=default
MCP_WORKER_NAME=default

# Your domain (used by Caddy for TLS)
DOMAIN=ninetrix.yourdomain.com
